generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                  @id @default(uuid())
  clerkId           String                  @unique
  email             String                  @unique
  firstName         String?
  lastName          String?
  imageUrl          String?
  role              Role                    @default(STUDENT)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  interests         String[]                @default([])
  isProfileComplete Boolean                 @default(false)
  phoneNumber       String?
  hasUsedTrial      Boolean                 @default(false)
  bookings          CallBooking[]
  authoredExams     Exam[]                  @relation("ExamAuthor")
  examDrafts        ExamDraft[]
  examResults       ExamResult[]
  sentNotices       Notice[]                @relation("NoticeSender")
  receivedNotices   Notice[]                @relation("NoticeReceiver")
  noticeReads       NoticeRead[]
  authoredQuestions Question[]              @relation("QuestionAuthor")
  workspaceAiUsages TeacherWorkspaceUsage[]
  authoredTopics    Topic[]                 @relation("TopicAuthor")
  adminWorkspace    Workspace?              @relation("WorkspaceAdmin")
  allowedExams      Exam[]                  @relation("ExamAllowedStudents")
  studentWorkspaces Workspace[]             @relation("WorkspaceStudent")
  teacherWorkspaces Workspace[]             @relation("WorkspaceTeacher")
}

enum WorkspaceStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

model Workspace {
  id                 String                  @id @default(uuid())
  name               String
  description        String?
  logoUrl            String?
  contactEmail       String?
  contactPhone       String?
  address            String?
  status             WorkspaceStatus         @default(ACTIVE)
  aiGenerationsCount Int                     @default(0)
  aiLimit            Int                     @default(10)
  aiLastResetDate    DateTime                @default(now())
  aiUnlimited        Boolean                 @default(false)
  adminId            String                  @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  maxStudents        Int                     @default(100)
  maxTeachers        Int                     @default(5)
  maxExams           Int                     @default(10)
  maxConcurrentExams Int                     @default(100)
  maxQuestions       Int                     @default(500)
  trialExpiresAt     DateTime?
  exams              Exam[]
  targetedNotices    Notice[]                @relation("NoticeWorkspaceTarget")
  questions          Question[]
  teacherAiUsages    TeacherWorkspaceUsage[]
  topics             Topic[]
  admin              User                    @relation("WorkspaceAdmin", fields: [adminId], references: [id])
  students           User[]                  @relation("WorkspaceStudent")
  teachers           User[]                  @relation("WorkspaceTeacher")
}

model TeacherWorkspaceUsage {
  id                 String    @id @default(uuid())
  workspaceId        String
  teacherId          String
  aiGenerationsCount Int       @default(0)
  aiLimit            Int       @default(5)
  teacher            User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, teacherId])
}

model Topic {
  id          String     @id @default(uuid())
  name        String
  isGlobal    Boolean    @default(false)
  workspaceId String?
  authorId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
  author      User?      @relation("TopicAuthor", fields: [authorId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

model Question {
  id            String         @id @default(uuid())
  text          String
  imageUrl      String?
  options       String[]
  correctAnswer String
  isPublic      Boolean        @default(false)
  topicId       String
  workspaceId   String?
  authorId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  exams         ExamQuestion[]
  author        User?          @relation("QuestionAuthor", fields: [authorId], references: [id])
  topic         Topic          @relation(fields: [topicId], references: [id])
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id])
}

model Exam {
  id                   String            @id @default(uuid())
  title                String
  description          String?
  logoUrl              String?
  contactInfo          String?
  workspaceId          String
  isPublic             Boolean           @default(false)
  status               ExamStatus        @default(ACTIVE)
  passMarks            Float
  duration             Int
  marksPerQuestion     Float             @default(1)
  negativeMarksEnabled Boolean           @default(false)
  negativeMarksValue   Float             @default(0)
  resultPublishMode    ResultPublishMode @default(INSTANT)
  customPublishDate    DateTime?
  showCorrectAnswers   Boolean           @default(true)
  showDetailedLog      Boolean           @default(true)
  allowPdfDownload     Boolean           @default(true)
  examExperience       ExamExperienceType @default(BOTH)
  startTime            DateTime?
  endTime              DateTime?
  authorId             String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  password             String?
  author               User?             @relation("ExamAuthor", fields: [authorId], references: [id])
  workspace            Workspace         @relation(fields: [workspaceId], references: [id])
  drafts               ExamDraft[]
  questions            ExamQuestion[]
  results              ExamResult[]
  allowedStudents      User[]            @relation("ExamAllowedStudents")
}

model ExamQuestion {
  examId     String
  questionId String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
}

model ExamResult {
  id        String   @id @default(uuid())
  score     Float
  timeTaken Int
  answers   Json     @default("{}")
  examId    String
  studentId String
  createdAt DateTime @default(now())
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ExamDraft {
  id               String   @id @default(uuid())
  examId           String
  studentId        String
  answers          Json     @default("{}")
  timeLeft         Int
  lastActiveIndex  Int      @default(0)
  flaggedQuestions String   @default("[]")
  tabSwitches      Int      @default(0)
  updatedAt        DateTime @updatedAt
  exam             Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student          User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model SiteSetting {
  id                  String   @id @default(uuid())
  siteName            String   @default("ABCD Exam Hub")
  siteDescription     String?
  faviconUrl          String?
  primaryColor        String   @default("#FFD700")
  secondaryColor      String   @default("#000000")
  bannerText          String?
  logoUrl             String?
  mobileNo            String?
  whatsappNo          String?
  email               String?
  location            String?
  facebookUrl         String?
  twitterUrl          String?
  linkedinUrl         String?
  instagramUrl        String?
  youtubeUrl          String?
  threadsUrl          String?
  tiktokUrl           String?
  githubUrl           String?
  heroTopTitle        String?  @default("Smart Exam Solutions")
  heroTitle           String?
  heroSubtitle        String?
  heroVideoUrl        String?
  heroRightImageUrl   String?
  aboutUsTitle        String?  @default("About Our Platform")
  aboutUsText         String?
  aboutUsImageUrl     String?
  whyUsText           String?
  footerText          String?
  footerDescription   String?
  pricingTitle        String?  @default("Invest in Academic Excellence")
  pricingSubtitle     String?  @default("Smart plans crafted to grow with digital education.")
  updatedAt           DateTime @updatedAt
  showHeroStats       Boolean  @default(true)
  statExamsCount      Int?
  statTeachersCount   Int?
  statWorkspacesCount Int?
  trialDays           Int      @default(7)
  trialMaxStudents    Int      @default(50)
  trialMaxTeachers    Int      @default(1)
  trialMaxExams       Int      @default(5)
  trialAiLimit        Int      @default(10)
}

model DynamicPage {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  linkUrl   String?
  title     String?
  subtitle  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  content   String
  avatarUrl String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingPlan {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  price1Month        Float    @default(0)
  price6Month        Float    @default(0)
  price12Month       Float    @default(0)
  maxStudents1Month  Int      @default(0)
  maxStudents6Month  Int      @default(0)
  maxStudents12Month Int      @default(0)
  maxTeachers1Month  Int      @default(0)
  maxTeachers6Month  Int      @default(0)
  maxTeachers12Month Int      @default(0)
  maxExams1Month     Int      @default(0)
  maxExams6Month     Int      @default(0)
  maxExams12Month    Int      @default(0)
  aiLimit1Month      Int      @default(0)
  aiLimit6Month      Int      @default(0)
  aiLimit12Month     Int      @default(0)
  features           String[]
  buttonText         String   @default("Get Started")
  buttonLink         String?
  isPopular          Boolean  @default(false)
  isActive           Boolean  @default(true)
  isCustom           Boolean  @default(false)
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model NavbarItem {
  id         String   @id @default(uuid())
  label      String
  href       String
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  isExternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  whatsapp  String?
  subject   String?
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallBooking {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  date      DateTime
  timeSlot  String
  status    String   @default("SCHEDULED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     String?
  userId    String?
  isRead    Boolean  @default(false)
  user      User?    @relation(fields: [userId], references: [id])
}

model BookingSetting {
  id           String   @id @default(uuid())
  workingDays  String[] @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"])
  startTime    String   @default("09:00")
  endTime      String   @default("17:00")
  slotDuration Int      @default(30)
  autoApprove  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model Notice {
  id                String           @id @default(uuid())
  title             String
  content           String
  targetType        NoticeTargetType
  senderId          String
  targetWorkspaceId String?
  targetUserId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  sender            User             @relation("NoticeSender", fields: [senderId], references: [id], onDelete: Cascade)
  targetUser        User?            @relation("NoticeReceiver", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetWorkspace   Workspace?       @relation("NoticeWorkspaceTarget", fields: [targetWorkspaceId], references: [id], onDelete: Cascade)
  reads             NoticeRead[]
}

model NoticeRead {
  id       String   @id @default(uuid())
  noticeId String
  userId   String
  readAt   DateTime @default(now())
  notice   Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
}

model Advantage {
  id          String   @id @default(uuid())
  title       String
  description String
  iconName    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  iconName    String?
  link        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  features    String[] @default([])
  isPrimary   Boolean  @default(false)
  iconColor   String?
}

model UserGuide {
  id          String          @id @default(uuid())
  role        Role            @unique
  title       String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  icon        String?         @default("BookOpen")
  items       UserGuideItem[]
}

model UserGuideItem {
  id          String    @id @default(uuid())
  guideId     String
  title       String
  description String
  order       Int       @default(0)
  guide       UserGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum ExamStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum ResultPublishMode {
  INSTANT
  EXAM_END
  CUSTOM
}

enum ExamExperienceType {
  CLASSIC
  PREMIUM
  BOTH
}

enum NoticeTargetType {
  ALL_ADMINS
  WORKSPACE_ADMINS
  WORKSPACE_TEACHERS
  WORKSPACE_STUDENTS
  ALL_TEACHERS
  ALL_STUDENTS
  SPECIFIC_USER
}
